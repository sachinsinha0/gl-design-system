{
  "name": "@gl/elements",
  "version": "0.0.1",
  "type": "module",
  "description": "Magna design system (Tamagui-based) — vendored from gl-app-native/packages/elements.",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./icons": "./src/icons/index.ts",
    "./hooks": "./src/hooks/index.ts",
    "./theme": "./src/theme/index.ts",
    "./css/*": "./src/css/*"
  },
  "files": [
    "src"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "react-native-edge-to-edge": "*",
    "react-native-web": ">=0.20",
    "tamagui": "^1.126.4"
  },
  "optionalDependencies": {
    "react-native-edge-to-edge": "*"
  },
  "peerDependenciesMeta": {
    "react-native-edge-to-edge": {
      "optional": true
    }
  }
}
