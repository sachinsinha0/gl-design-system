{
  "name": "gl-design-system",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "yarn@4.5.0",
  "workspaces": [
    "packages/*",
    "apps/*",
    "ai/*"
  ],
  "scripts": {
    "dev": "yarn workspace @gl/showcase dev",
    "build": "yarn workspaces foreach --all --topological --no-private run build",
    "preview": "yarn workspace @gl/showcase preview",
    "test": "yarn workspace @gl/showcase test",
    "test:watch": "yarn workspace @gl/showcase test:watch",
    "typecheck": "yarn workspaces foreach --all --topological run typecheck"
  },
  "resolutions": {
    "tamagui": "1.126.4",
    "@tamagui/core": "1.126.4",
    "@tamagui/animations-react-native": "1.126.4",
    "@tamagui/font-inter": "1.126.4",
    "@tamagui/lucide-icons": "1.126.4",
    "@tamagui/portal": "1.126.4",
    "@tamagui/react-native-media-driver": "1.126.4",
    "@tamagui/shorthands": "1.126.4",
    "@floating-ui/react": "0.26.28"
  }
}
