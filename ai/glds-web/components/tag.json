{
  "id": "tag",
  "name": "Tag",
  "dsId": "glds-web",
  "summary": "Small rounded label for status/category. Variant axes from the Figma Components page: Size (Small|Large) × Style (Filled|Tonal|Outlined|Outlined Ghost) × Colour (Primary|Secondary|Success|Error) × Icon (Left|Right). Tags are NOT actions — color carries meaning.",
  "anatomy": [
    { "part": "container", "description": "`<span class=\"glds-tag glds-tag--{style} glds-tag--{color} glds-tag--{size}\">`.", "required": true },
    { "part": "leading-icon", "description": "Material Icons span before label (optional)." },
    { "part": "label", "description": "Short 1–2 word text.", "required": true },
    { "part": "trailing-icon", "description": "Material Icons span after label (optional)." }
  ],
  "props": [
    { "name": "label", "type": "string", "required": true },
    { "name": "size", "type": "'Small' | 'Large'", "default": "Small" },
    { "name": "style", "type": "'Filled' | 'Tonal' | 'Outlined' | 'Outlined Ghost'", "default": "Tonal" },
    { "name": "color", "type": "'Primary' | 'Secondary' | 'Success' | 'Error'", "default": "Primary" },
    { "name": "iconPosition", "type": "'none' | 'left' | 'right'", "default": "none" }
  ],
  "variants": [
    { "axis": "size", "values": ["Small", "Large"], "default": "Small" },
    { "axis": "style", "values": ["Filled", "Tonal", "Outlined", "Outlined Ghost"], "default": "Tonal" },
    { "axis": "color", "values": ["Primary", "Secondary", "Success", "Error"], "default": "Primary" },
    { "axis": "icon", "values": ["none", "left", "right"], "default": "none" }
  ],
  "states": [
    { "name": "default", "description": "Tags are static — no hover/focus/active." }
  ],
  "a11y": [
    "Tags must always include text — never indicate state via color alone.",
    "If a tag is interactive (filter), convert it to a `<button>` and respect button rules.",
    "Color pairings: Success/Error from UI Feedback; Primary/Secondary for category."
  ],
  "examples": [
    {
      "label": "Success tonal tag",
      "language": "html",
      "snippet": "<span class=\"glds-tag glds-tag--tonal glds-tag--success glds-tag--small\">Active</span>"
    },
    {
      "label": "Primary outlined tag with leading icon",
      "language": "html",
      "snippet": "<span class=\"glds-tag glds-tag--outlined glds-tag--primary glds-tag--large\">\n  <span class=\"material-icons\" aria-hidden=\"true\">star</span>\n  Featured\n</span>"
    }
  ],
  "doNot": [
    "Use a tag as a button (it's a label).",
    "Render an Error tag without the word ('Error', 'Failed', etc.).",
    "Add colors outside the four defined (Primary/Secondary/Success/Error).",
    "Use long phrases — keep to 1–2 words."
  ],
  "tokensUsed": ["--glds-primary-500", "--glds-primary-50", "--glds-secondary-500", "--glds-feedback-success-500", "--glds-feedback-success-50", "--glds-feedback-error-500", "--glds-feedback-error-50"]
}
