{
  "id": "text-input",
  "name": "Text Input",
  "dsId": "glds-web",
  "summary": "Form text input as defined in Figma. Variant axes: Size (Small|Medium) × State (Enabled|Hovered|Focused|Disabled|Error) × Has Value × Adornment × Icon End × Helper Text. Every input has a real `<label>`; validate on blur, never per keystroke.",
  "anatomy": [
    { "part": "label", "description": "Real `<label>` with `for` matching the input `id`.", "required": true },
    { "part": "field-container", "description": "Bordered container (`--glds-grey-contrast-60` border, `--glds-radius-md`)." },
    { "part": "leading-adornment", "description": "Optional Material Icon or text prefix (currency, unit)." },
    { "part": "input", "description": "`<input>` — placeholder in `--glds-grey-secondary-text`, value in `--glds-grey-primary-text`.", "required": true },
    { "part": "trailing-icon", "description": "Optional Material Icon (clear, password reveal)." },
    { "part": "helper-text", "description": "12px caption; sits below the field; switches to error styling on invalid." }
  ],
  "props": [
    { "name": "id", "type": "string", "required": true, "description": "Used by the `<label for>` association." },
    { "name": "label", "type": "string", "required": true },
    { "name": "name", "type": "string" },
    { "name": "type", "type": "'text' | 'email' | 'password' | 'number' | 'tel' | 'url'", "default": "text" },
    { "name": "value", "type": "string" },
    { "name": "placeholder", "type": "string" },
    { "name": "size", "type": "'Small' | 'Medium'", "default": "Medium" },
    { "name": "state", "type": "'Enabled' | 'Hovered' | 'Focused' | 'Disabled' | 'Error'", "default": "Enabled" },
    { "name": "helperText", "type": "string" },
    { "name": "errorMessage", "type": "string" },
    { "name": "adornment", "type": "string", "description": "Leading adornment text or icon name." },
    { "name": "iconEnd", "type": "string", "description": "Trailing Material Icon name." }
  ],
  "variants": [
    { "axis": "size", "values": ["Small", "Medium"], "default": "Medium" },
    { "axis": "state", "values": ["Enabled", "Hovered", "Focused", "Disabled", "Error"], "default": "Enabled" },
    { "axis": "hasValue", "values": ["true", "false"], "default": "false" },
    { "axis": "adornment", "values": ["true", "false"], "default": "false" },
    { "axis": "iconEnd", "values": ["true", "false"], "default": "false" },
    { "axis": "helperText", "values": ["true", "false"], "default": "false" }
  ],
  "states": [
    { "name": "Enabled", "description": "Grey border (`--glds-grey-contrast-60`)." },
    { "name": "Hovered", "description": "Darker border (`--glds-grey-contrast-150`)." },
    { "name": "Focused", "description": "Primary 500 border + visible focus ring." },
    { "name": "Error", "description": "Error 500 border; helper text replaced/augmented with error message (grey 800)." },
    { "name": "Disabled", "description": "Disabled Text color + muted border; never whole-element `opacity`." }
  ],
  "a11y": [
    "Every input has an associated `<label>` (via `for`/`id`).",
    "Error message text is grey 800 (`--glds-feedback-error-800`) — never the Error 500 hex (fails contrast as text).",
    "Errors pair color with a written message; never color alone.",
    "Validate on blur; preserve entered values on failed submission."
  ],
  "examples": [
    {
      "label": "Enabled with helper text",
      "language": "html",
      "snippet": "<div class=\"glds-field glds-field--medium\">\n  <label class=\"glds-field__label\" for=\"email\">Email</label>\n  <input class=\"glds-field__input\" id=\"email\" name=\"email\" type=\"email\" placeholder=\"you@example.com\" />\n  <p class=\"glds-field__helper\">We won't share this address.</p>\n</div>"
    },
    {
      "label": "Error state",
      "language": "html",
      "snippet": "<div class=\"glds-field glds-field--medium glds-field--error\">\n  <label class=\"glds-field__label\" for=\"pw\">Password</label>\n  <input class=\"glds-field__input\" id=\"pw\" name=\"password\" type=\"password\" />\n  <p class=\"glds-field__helper glds-field__helper--error\">At least 8 characters.</p>\n</div>"
    }
  ],
  "doNot": [
    "Skip the label and rely on a placeholder.",
    "Render an Error state without an accompanying message.",
    "Disable a field via `opacity: 0.5`.",
    "Color the error message in `--glds-feedback-error-500` — it fails contrast as text on white."
  ],
  "tokensUsed": ["--glds-primary-500", "--glds-grey-primary-text", "--glds-grey-secondary-text", "--glds-grey-contrast-60", "--glds-grey-contrast-150", "--glds-grey-disabled-text", "--glds-feedback-error-500", "--glds-feedback-error-800"]
}
